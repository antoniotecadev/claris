// prisma/schema.prisma
// Este arquivo é usado para definir o modelo de dados e a configuração do Prisma. 

// Configuração do cliente Prisma que vai interagir com o banco de dados.
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// Configuração da fonte de dados, indicando o tipo de banco de dados e a URL de conexão.
datasource db { 
  provider = "postgresql"
  // url: esta definida no prisma.config.ts 
}

