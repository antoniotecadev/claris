PORT_NEST=3001
PORT_PRISMA=51212

# ==============================================================================
# CONFIGURAÇÕES DO FRONTEND (Next.js)
# ==============================================================================
NEXT_PUBLIC_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:${PORT_NEST}/api/v1"

# ==============================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS (Usadas pelo Docker e pelo Backend)
# ==============================================================================

DB_HOST=postgres
DB_PORT=5432
DB_USER=claris_user
DB_PASSWORD=claris_password
DB_NAME=claris_saas
DB_CONTAINER=claris-db

# IMPORTANTE: No Docker, o host do banco passa a ser o nome do serviço (postgres)
# Para rodar migrações locais fora do docker, você usaria 'localhost'. No docker, use 'postgres'.
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"


